{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "dotnet",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/misas-thai-street-cuisine/misas-thai-street-cuisine.csproj"
            ],
            "cwd": "${workspaceFolder}/misas-thai-street-cuisine",
            "stopAtEntry": false,
            // Removed serverReadyAction to prevent double tab opening
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ]
}