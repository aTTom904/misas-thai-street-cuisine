{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5106",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Debug Firefox",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "dotnet",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/misas-thai-street-cuisine/misas-thai-street-cuisine.csproj"
            ],
            "cwd": "${workspaceFolder}/misas-thai-street-cuisine",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ]
}