@using Data
@page "/Menu"
@rendermode InteractiveServer
@inject Services.ShoppingCartService Cart

<div class="menu-container">
    <h2 class='page-header-text'>Pick Your Flavor Fix</h2>
    <div class="vegan-blurb">
        <p class="vegan-text">It's Vegan!</p>
        <img src="/Resources/Images/Icons/curved-arrow-right-short.png"/>
    </div>
    <div class="menu-section">
        <h3 class="section-header-text">Thai Herb Sausage (Sai Oua)</h3>
        <ul>
            @foreach (var sausage in MenuData.SausageTypes)
            {
                <li>
                    <span>@sausage.Name - @sausage.Price.ToString("C")</span>
                    <button @onclick="() => AddToOrder(sausage.Name)">+</button>
                </li>
            }
        </ul>
    </div>

    <div class="gotta-try-blurb">
        <p class="gotta-try-text">You gotta try this stuff!</p>
        <img src="/Resources/Images/Icons/curved-arrow-left-short.png" />
    </div>
    <div class="menu-section">
        <h3 class="section-header-text">Sides</h3>
        <ul>
            @foreach (var side in MenuData.SideDishes)
            {
                <li>
                    <span>@side.Name - @side.Price.ToString("C")</span>
                    <button @onclick="() => AddToOrder(side.Name)">+</button>
                </li>
            }
        </ul>
    </div>

    <div class="menu-section">
        <h3 class="section-header-text">Packages</h3>
        <ul>
            @foreach (var platter in MenuData.Platters)
            {
                <li>
                    <span>@platter.Name - @platter.Price.ToString("C")</span>
                    <button @onclick="() => AddToOrder(platter.Name)">+</button>
                </li>
            }
        </ul>
    </div>
</div>

@code {
    // Example method that could be used to add items to an order
    private void AddToOrder(string itemName)
    {

    }
}