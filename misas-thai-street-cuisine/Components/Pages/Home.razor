@page "/"
@using Blazorise
@using Blazorise.Bootstrap
@using Blazorise.Icons.FontAwesome

<PageTitle>Home</PageTitle>

<div class="container-fluid">
    <div class="social-blurb">
        <p class="social-text">Check out our socials!</p>
        <img src="/Resources/Images/Icons/down-arrow.png" class="arrow-down" />
        <img src="/Resources/Images/Icons/curved-arrow.png" class="curved-arrow" />
    </div>
    <div class="carousel-container">
        <div class="carousel-overlay">
            <div class="carousel-text text-center">
                <p class="overlay-text">Welcome to Misa's</p>
                <a href="/Menu" class="button image-button">Let's Cook!</a>
            </div>
        </div>
        <div id="foodCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img class="d-block w-100" src="/Resources/Images/Food/sai-oua.jpg" alt="Sai Oua Sausage" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void PrevSlide()
    {
        // Logic to go to the previous slide
    }

    private void NextSlide()
    {
        // Logic to go to the next slide
    }
}
