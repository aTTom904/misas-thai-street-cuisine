@inherits LayoutComponentBase

<header class="navbar">
    <div class="nav-left">
        <a href="menu">Menu</a>
        <a href="about">About</a>
    </div>
    <div class="logo-container">
        <a href="/">
            <img src="Resources/Images/Logos/GLD M RED CHLI WHT BG NO TXT.png" alt="Logo" class="logo" />
        </a>
    </div>
    <div class="nav-right">
        <a href="gallery">Gallery</a>
        <a href="contact">Contact</a>
    </div>
</header>

<div class="main-content">
    @Body
</div>

<style>
    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: goldenrod;
        padding: 0 20px;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 80px;
        z-index: 100;
    }

    .nav-left{
        display: flex;
        gap: 40px; /* Increase the gap for more spacing */
    }

    .nav-right {
        display: flex;
        gap: 40px; /* Increase the gap for more spacing */
    }

    .nav-left a, .nav-right a {
        color: white;
        text-decoration: none;
        font-size: 22px; /* Adjust the font size */
        font-weight: bold;
        line-height: 60px;
    }

    .logo-container {
        position: absolute;
        left: 50%;
        transform: translate(-50%, 10%);
        background-color: goldenrod;
        border-radius: 50%;
        height: 165px;
        width: 165px;
        display: flex;
        align-items: center;
        justify-content: center;
        top: -20px;
    }

    .logo {
        max-height: 150px;
        max-width: 150px;
        border-radius: 50%;
    }

    .main-content {
        margin-top: 100px;
    }

    body {
        overflow: -moz-scrollbars-none;
        -ms-overflow-style: none; /* Internet Explorer and Edge */
    }

    body::-webkit-scrollbar {
        display: none; /* Safari and Chrome */
    }

</style>
